# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://localhost:9000

# JWT Configuration
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168
# JWT_VALIDATION_MODE: "local" (default) or "remote"
JWT_VALIDATION_MODE=local
# API_URL: external validation URL required when JWT_VALIDATION_MODE is "remote"
API_URL=http://localhost:8080/auth/validate

# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# Auth (simple user — thay bằng DB trong production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Embed ticket auth
EMBED_TICKET_VERIFY_URL=https://tecs.vn/v1/api/manage/embed-ticket/verify
EMBED_TICKET_SERVICE_KEY=replace-with-admin-issued-service-key

# Upload Limits
MAX_UPLOAD_SIZE_MB=50

# Allowed extensions per resource type (comma-separated)
ALLOWED_IMAGE_EXTS=jpg,jpeg,png,gif,webp,svg,bmp,ico
ALLOWED_FILE_EXTS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,csv,zip,rar,7z
ALLOWED_VIDEO_EXTS=mp4,webm,ogg,avi,mov,mkv

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
